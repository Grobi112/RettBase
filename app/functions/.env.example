# SMTP-Konfiguration für sendEmail Cloud Function
# Kopiere diese Datei nach .env und trage deine Werte ein.

SMTP_USER=deine@email.de
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# IMAP für eingehende Antworten (pollInboundEmail)
IMAP_HOST=imap.strato.de
IMAP_PORT=993

# SMTP_PASS = Passwort für das SMTP-Konto (SMTP_USER)
# NICHT in .env eintragen! Stattdessen im Terminal ausführen:
#   firebase functions:secrets:set SMTP_PASS
# "SMTP_PASS" ist der feste Name des Secrets – NICHT ersetzen!
# Danach Passwort interaktiv eingeben.
