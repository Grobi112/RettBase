rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isSuperadmin() {
      let email = request.auth.token.email;
      return email != null && (
        email == 'admin@rettbase.de' ||
        (email.matches('.*@admin.rettbase.de') && email.matches('112@.*'))
      );
    }

    function belongsToCompany(kundenId) {
      return exists(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid));
    }

    function canAccessCompany(kundenId) {
      return isLoggedIn() && (belongsToCompany(kundenId) || isSuperadmin());
    }

    // Fallback: Nur lesen wenn berechtigt (restriktiver als vorher)
    match /{document=**} {
      allow read, write: if isLoggedIn();
    }

    // Collection-Group-Queries (für getAuthData)
    match /{path=**}/mitarbeiter/{mitarbeiterId} {
      allow read: if true;
      allow write: if isLoggedIn();
    }
    match /{path=**}/users/{userId} {
      allow read, write: if isLoggedIn();
    }

    // Kunden-Collections: Zugriff nur für Nutzer dieser Firma oder Superadmin
    match /kunden/{kundenId} {
      allow read, write: if canAccessCompany(kundenId);

      match /mitarbeiter/{mitarbeiterId} {
        allow read: if true;
        allow write: if canAccessCompany(kundenId);
      }

      match /users/{userId} {
        allow read, write: if canAccessCompany(kundenId);
        match /userTiles/{docId} {
          allow read, write: if canAccessCompany(kundenId);
        }
      }

      match /modules/{moduleId} {
        allow read, write: if canAccessCompany(kundenId);
      }

      match /chats/{chatId} {
        allow read, write: if canAccessCompany(kundenId);
        match /messages/{messageId} {
          allow read, write: if canAccessCompany(kundenId);
        }
      }

      match /{document=**} {
        allow read, write: if canAccessCompany(kundenId);
      }
    }

    match /settings/{document=**} {
      allow read, write: if isLoggedIn();
    }

    match /fcmTokens/{uid} {
      allow read, write: if isLoggedIn() && request.auth.uid == uid;
    }
  }
}
